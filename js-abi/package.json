{
    "name": "js-query-system-info",
    "version": "1.0.0",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "repository": {
        "type": "git",
        "url": "https://github.com/wuyouMaster/query_system_info"
    },
  "n-api": {
    "name": "js-query-system-info",
    "version": "1.0.0"
  },
  "napi": {
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc"
    ]
  },
    "scripts": {
        "build": "napi build --release --output-dir ../dist --platform",
        "release": "napi build --release --output-dir ../dist --js index.js --dts index.d.ts --platform",
        "artifacts": "napi artifacts",
        "test": "node -e \"const { jsGetCpuInfo } = require('../dist/index.js'); const info = jsGetCpuInfo(); console.log('CPU Info:', info); console.log('Tests passed!');\""
    },
    "dependencies": {
        "@napi-rs/cli": "^3.5.1",
        "query_system_info": "file:.."
    },
    "devDependencies": {
        "ts-node": "^10.0.0",
        "tsconfig-paths": "^4.0.0",
        "typescript": "^5.0.0"
    }
}
